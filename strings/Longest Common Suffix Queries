2026-05-28 | Longest Common Suffix Queries

	Question
Return indices of best matching container words.
	Key Insight
Suffix matching becomes easier if we:
		reverse all strings.
Then:
		common suffix
becomes:
		common prefix problem.
A Trie efficiently handles prefix matching.
	Approach
1.	Build Trie using reversed container words.
2.	At every Trie node store:
		bestIndex
		according to:
				smaller length
				then smaller index
3.	For each query:
		reverse query word
4.	Traverse Trie character by character.
5.	Last reachable node gives:
		best matching index.
	Time Complexity
	O(total characters)
	Space Complexity
	O(total characters)
	
Solution
class Solution {
 public:
  vector<int> stringIndices(vector<string>& wordsContainer,
                            vector<string>& wordsQuery) {
    vector<int> ans;
    int minIndex = 0;

    for (int i = 0; i < wordsContainer.size(); ++i) {
      insert(wordsContainer[i], i);
      if (wordsContainer[i].length() < wordsContainer[minIndex].length())
        minIndex = i;
    }

    for (const string& query : wordsQuery) {
      const int index = search(query);
      ans.push_back(index == -1 ? minIndex : index);
    }

    return ans;
  }

 private:
  shared_ptr<TrieNode> root = make_shared<TrieNode>();

  void insert(const string& word, int index) {
    shared_ptr<TrieNode> node = root;
    for (int i = word.length() - 1; i >= 0; --i) {
      const int j = word[i] - 'a';
      if (node->children[j] == nullptr)
        node->children[j] = make_shared<TrieNode>();
      node = node->children[j];
      if (node->length > word.length()) {
        node->length = word.length();
        node->index = index;
      }
    }
  }

  int search(const string& word) {
    shared_ptr<TrieNode> node = root;
    for (int i = word.length() - 1; i >= 0; --i) {
      const int j = word[i] - 'a';
      if (node->children[j] == nullptr)
        return node->index;
      node = node->children[j];
    }
    return node->index;
  }
};
