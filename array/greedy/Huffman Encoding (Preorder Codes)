2026-04-06 | Huffman Encoding (Preorder Codes)

	Question
Return all Huffman codes using preorder traversal.

	Approach
1.	Create a min-heap of nodes:
		(each node → freq, left, right)

2.	While heap size > 1:
		pop two smallest nodes  
		create new node with sum  
		assign:
			left = smaller  
			right = larger  
		push back into heap  

3.	Tree root remains.

4.	Traverse tree:
		preorder DFS  
		build binary codes  

	Time Complexity
	O(n log n)

	Space Complexity
	O(n)

	Solution

class Solution {
public:

    struct Node {
        int freq;
        Node* left;
        Node* right;

        Node(int f){
            freq = f;
            left = right = NULL;
        }
    };

    struct cmp {
        bool operator()(Node* a, Node* b){
            return a->freq > b->freq;
        }
    };

    void preorder(Node* root, string curr, vector<string>& ans){

        if(!root->left && !root->right){
            ans.push_back(curr);
            return;
        }

        if(root->left)
            preorder(root->left, curr + "0", ans);

        if(root->right)
            preorder(root->right, curr + "1", ans);
    }

    vector<string> huffmanCodes(string S, vector<int> f, int N) {

        priority_queue<Node*, vector<Node*>, cmp> pq;

        for(int i=0;i<N;i++){
            pq.push(new Node(f[i]));
        }

        while(pq.size() > 1){

            Node* left = pq.top(); pq.pop();
            Node* right = pq.top(); pq.pop();

            Node* newNode = new Node(left->freq + right->freq);

            newNode->left = left;
            newNode->right = right;

            pq.push(newNode);
        }

        Node* root = pq.top();

        vector<string> ans;

        preorder(root, "", ans);

        return ans;
    }
};

	Key Insight
Huffman encoding is built using a **greedy approach**:
always merge the two smallest frequencies.  

The tree structure ensures:
		shorter codes for higher frequency characters.
