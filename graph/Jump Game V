2026-05-24 | Jump Game V

	Question
Return maximum number of reachable indices.
	Key Insight
From one index,
answer depends on answers of smaller reachable indices.
This creates:
		overlapping subproblems
So:
		use DFS + memoization DP.
	Approach
1.	Define:
		dp[i] =
			max indices visitable starting from i
2.	Use DFS from each index.
3.	Explore:
		right side up to distance d
		until blocked by greater/equal value
4.	Similarly explore left side.
5.	Transition:
		dp[i] =
			1 + max(dp[next])
6.	Take maximum over all starting indices.
	Time Complexity
	O(n × d)
	Space Complexity
	O(n)
	Solution
class Solution {
public:
    int n;
    int dfs(int idx,
            vector<int>& arr,
            int d,
            vector<int>& dp){
        if(dp[idx] != -1)
            return dp[idx];
        int ans = 1;
        // move right
        for(int j = idx + 1;
            j <= min(n - 1, idx + d);
            j++){
            if(arr[j] >= arr[idx])
                break;
            ans = max(ans,
                      1 + dfs(j, arr, d, dp));
        }
        // move left
        for(int j = idx - 1;
            j >= max(0, idx - d);
            j--){
            if(arr[j] >= arr[idx])
                break;
            ans = max(ans,
                      1 + dfs(j, arr, d, dp));
        }
        return dp[idx] = ans;
    }
    int maxJumps(vector<int>& arr, int d) {
        n = arr.size();
        vector<int> dp(n, -1);
        int ans = 1;
        for(int i = 0; i < n; i++){
            ans = max(ans,
                      dfs(i, arr, d, dp));
        }
        return ans;
    }
};
	Key Insight
Each index behaves like:
		a node in directed graph  
Since jumps only go to smaller values,
no cycles exist,
which makes memoized DFS very efficient.
