2026-03-28 | Articulation Points in Graph

	Question
Return all articulation points.  
If none exist → return {-1}.

	Approach (Tarjan’s Algorithm)
1.	Use DFS and track:
		disc[u] → discovery time  
		low[u] → lowest reachable time  
		parent[u]  

2.	Conditions for articulation point:
	- Case 1 (root node):
			has more than 1 child in DFS tree  
	- Case 2 (non-root):
			low[child] ≥ disc[u]

3.	Build adjacency list and run DFS for all components.

	Time Complexity
	O(V + E)

	Space Complexity
	O(V)

	Solution

class Solution {
public:

    void dfs(int u, int parent, vector<vector<int>>& adj,
             vector<int>& disc, vector<int>& low,
             vector<bool>& vis, vector<bool>& isArt,
             int &time) {

        vis[u] = true;
        disc[u] = low[u] = time++;
        int children = 0;

        for(int v : adj[u]){

            if(v == parent) continue;

            if(!vis[v]){
                children++;

                dfs(v, u, adj, disc, low, vis, isArt, time);

                low[u] = min(low[u], low[v]);

                if(parent != -1 && low[v] >= disc[u])
                    isArt[u] = true;
            }
            else{
                low[u] = min(low[u], disc[v]);
            }
        }

        if(parent == -1 && children > 1)
            isArt[u] = true;
    }

    vector<int> articulationPoints(int V, vector<vector<int>>& edges) {

        vector<vector<int>> adj(V);

        for(auto &e : edges){
            adj[e[0]].push_back(e[1]);
            adj[e[1]].push_back(e[0]);
        }

        vector<int> disc(V, -1), low(V, -1);
        vector<bool> vis(V, false), isArt(V, false);

        int time = 0;

        for(int i=0;i<V;i++){
            if(!vis[i])
                dfs(i, -1, adj, disc, low, vis, isArt, time);
        }

        vector<int> ans;

        for(int i=0;i<V;i++){
            if(isArt[i]) ans.push_back(i);
        }

        if(ans.empty()) return {-1};

        sort(ans.begin(), ans.end());
        return ans;
    }
};

	Key Insight
A node is critical if:
it cannot reach ancestors without passing through itself.  

This is captured using:
		low[child] ≥ disc[parent]

Tarjan’s algorithm efficiently finds all such nodes in **O(V + E)** time.
